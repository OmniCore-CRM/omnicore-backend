generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  ADMIN
  TEAM_LEAD
  AGENT
  VIEWER
}

enum UserLifecycleStatus {
  INVITED
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum ConversationChannel {
  WEBSITE
  WHATSAPP
  INSTAGRAM
  EMAIL
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  SNOOZED
}

enum ConversationActivityAction {
  STATUS_CHANGED
  TEAM_ASSIGNED
  TEAM_UNASSIGNED
  AUTO_TEAM_ASSIGNED
}

enum MessageSender {
  CUSTOMER
  AGENT
  SYSTEM
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum AttachmentUploadedFrom {
  AGENT
  CUSTOMER_WIDGET
}

enum TicketStatus {
  OPEN
  PENDING
  ESCALATED
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SlaStatus {
  ON_TRACK
  AT_RISK
  BREACHED
  PAUSED
}

enum TicketActivityAction {
  TICKET_CREATED
  TICKET_CREATED_FROM_WIDGET
  TICKET_UPDATED
  STATUS_CHANGED
  PRIORITY_CHANGED
  ASSIGNED
  UNASSIGNED
  NOTE_ADDED
  MESSAGE_RECEIVED_ON_WIDGET
  TEAM_ASSIGNED
  TEAM_UNASSIGNED
  AUTO_TEAM_ASSIGNED
  SLA_UPDATED
  SLA_BREACHED
}

enum AssignmentRuleTargetType {
  CONVERSATION
  TICKET
}

enum AssignmentRuleConditionType {
  CHANNEL
  PRIORITY
  TAG
}

enum NotificationType {
  TICKET_ASSIGNED
  CONVERSATION_ASSIGNED
  TICKET_TEAM_ASSIGNED
  CONVERSATION_TEAM_ASSIGNED
  TICKET_MENTION
  CONVERSATION_MENTION
  INVITE_ACCEPTED
  USER_ACTIVATED
  TEAM_MEMBER_ADDED
  ROLE_CHANGED
  FEEDBACK_DETRACTOR_ESCALATION
}

enum FeedbackSurveyType {
  CSAT
  NPS
}

enum FeedbackSurveyStatus {
  PENDING
  SENT
  COMPLETED
  EXPIRED
}

enum FeedbackTriggerSource {
  TICKET_RESOLVED
  CONVERSATION_RESOLVED
}

enum FeedbackTriggerMode {
  DISABLED
  CSAT
  NPS
  BOTH
}

enum FeedbackSentiment {
  DETRACTOR
  NEUTRAL
  SATISFIED
  PASSIVE
  PROMOTER
}

enum FeedbackEscalationStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

enum EmailProvider {
  RESEND
}

enum EmailAccountStatus {
  ACTIVE
  DISABLED
}

enum WebhookProvider {
  WHATSAPP
  EMAIL
}

enum ChannelRetryState {
  PENDING
  RETRY_SCHEDULED
  PROCESSING
  SUCCEEDED
  FAILED
  EXHAUSTED
}

enum ChannelDlqReason {
  RETRY_EXHAUSTED
  DELIVERY_UNMATCHED
  INVALID_LIFECYCLE_TRANSITION
  PROVIDER_PROCESSING_FAILURE
}

enum ChannelDlqState {
  OPEN
  REPROCESSING
  RESOLVED
  DISMISSED
}

enum ReconciliationRunStatus {
  STARTED
  COMPLETED
  FAILED
}

enum ProviderAccountStatus {
  ACTIVE
  DISABLED
}

enum WidgetArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DomainVerificationStatus {
  NOT_CONFIGURED
  PENDING
  VERIFIED
  FAILED
}

enum DomainSslStatus {
  NOT_CONFIGURED
  PENDING
  READY
  FAILED
}

enum DomainStatus {
  NOT_CONFIGURED
  PENDING
  READY
  FAILED
}

enum AIInteractionRequestType {
  REPLY_SUGGESTION
  SUMMARY
  ROUTING_SUGGESTION
  ESCALATION_RECOMMENDATION
}

enum AIInteractionUserAction {
  ACCEPTED
  EDITED
  REJECTED
}

model Company {
  id                   String  @id @default(cuid())
  name                 String
  isActive             Boolean @default(true)
  companySlug          String? @unique @db.VarChar(63)
  supportPortalEnabled Boolean @default(false)
  customSupportDomain  String?                  @unique @db.VarChar(255)
  verificationStatus   DomainVerificationStatus @default(NOT_CONFIGURED)
  verificationToken    String?                  @db.VarChar(128)
  verifiedAt           DateTime?
  sslStatus            DomainSslStatus          @default(NOT_CONFIGURED)
  domainStatus         DomainStatus             @default(NOT_CONFIGURED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                   User[]
  customers               Customer[]
  conversations           Conversation[]
  messages                Message[]
  widgetInstallations     WidgetInstallation[]
  widgetFaqEntries        WidgetFaqEntry[]
  widgetArticleCategories WidgetArticleCategory[]
  widgetArticles          WidgetArticle[]
  tickets                 Ticket[]
  ticketNotes             TicketNote[]
  ticketActivities        TicketActivity[]
  conversationActivities  ConversationActivity[]
  savedReplies            SavedReply[]
  tags                    Tag[]
  customerTags            CustomerTag[]
  conversationTags        ConversationTag[]
  ticketTags              TicketTag[]
  teams                   Team[]
  teamMembers             TeamMember[]
  attachments             Attachment[]
  auditLogs               AuditLog[]
  slaPolicies             SlaPolicy[]
  assignmentRules         AssignmentRule[]
  emailAccounts           EmailAccount[]
  whatsAppAccounts        WhatsAppAccount[]
  webhookReplayLedger     WebhookReplayLedger[]
  messageRetryStates      MessageRetryState[]
  channelDeadLetterItems  ChannelDeadLetterItem[]
  reconciliationRuns      ReconciliationRun[]
  authSessions            AuthSession[]
  userInviteTokens        UserInviteToken[]
  notifications           Notification[]
  feedbackTriggerConfigs  FeedbackTriggerConfig[]
  feedbackSurveys         FeedbackSurvey[]
  feedbackResponses       FeedbackResponse[]
  feedbackEscalations     FeedbackEscalation[]
  aiInteractions          AIInteraction[]
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String

  firstName String
  lastName  String

  role     UserRole            @default(AGENT)
  isActive Boolean             @default(true)
  status   UserLifecycleStatus @default(ACTIVE)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedTickets        Ticket[]               @relation("TicketAssignee")
  assignedConversations  Conversation[]         @relation("ConversationAssignee")
  createdTickets         Ticket[]               @relation("TicketCreator")
  ticketNotes            TicketNote[]           @relation("TicketNoteAuthor")
  ticketActivities       TicketActivity[]       @relation("TicketActivityActor")
  conversationActivities ConversationActivity[] @relation("ConversationActivityActor")
  savedReplies           SavedReply[]           @relation("SavedReplyCreator")
  widgetArticles         WidgetArticle[]        @relation("WidgetArticleCreator")
  teamMemberships        TeamMember[]
  attachments            Attachment[]           @relation("AttachmentUploader")
  auditLogs              AuditLog[]             @relation("AuditLogActor")
  authSessions           AuthSession[]
  passwordResetTokens    PasswordResetToken[]
  sentInviteTokens       UserInviteToken[]      @relation("UserInviteActor")
  receivedInviteTokens   UserInviteToken[]      @relation("UserInviteTarget")
  notifications          Notification[]
  assignedFeedbackSurveys     FeedbackSurvey[]     @relation("FeedbackSurveyAssignee")
  assignedFeedbackEscalations FeedbackEscalation[] @relation("FeedbackEscalationAssignee")
  aiInteractions         AIInteraction[]

  @@index([companyId, firstName, lastName])
  @@index([companyId, status, firstName, lastName])
}

model UserInviteToken {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("UserInviteTarget", fields: [userId], references: [id], onDelete: Cascade)

  invitedById String?
  invitedBy   User?   @relation("UserInviteActor", fields: [invitedById], references: [id], onDelete: SetNull)

  tokenHash String @unique

  expiresAt  DateTime
  consumedAt DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([invitedById])
  @@index([expiresAt])
  @@index([consumedAt])
  @@index([revokedAt])
}

model PasswordResetToken {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([consumedAt])
}

model AuthSession {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([companyId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Customer {
  id String @id @default(cuid())

  // Tenant ownership
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Basic customer identity
  firstName String
  lastName  String?

  email String?
  phone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Customer communication history
  conversations Conversation[]
  tickets       Ticket[]
  tags          CustomerTag[]
  attachments   Attachment[]
  feedbackSurveys   FeedbackSurvey[]
  feedbackResponses FeedbackResponse[]
}

model Conversation {
  id String @id @default(cuid())

  // Tenant ownership
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Customer relationship
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  // Communication channel
  channel ConversationChannel
  status  ConversationStatus  @default(OPEN)
  subject String?

  assigneeId String?
  assignee   User?   @relation("ConversationAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages    Message[]
  tickets     Ticket[]
  tags        ConversationTag[]
  activities  ConversationActivity[]
  attachments Attachment[]
  feedbackSurveys   FeedbackSurvey[]
  feedbackResponses FeedbackResponse[]
  aiInteractions AIInteraction[]

  @@index([companyId])
  @@index([customerId])
  @@index([status])
  @@index([assigneeId])
  @@index([teamId])
  @@index([companyId, updatedAt, id])
  @@index([companyId, status, updatedAt, id])
  @@index([companyId, assigneeId, updatedAt, id])
  @@index([companyId, teamId, updatedAt, id])
  @@index([companyId, channel, updatedAt, id])
}

model ConversationActivity {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  actorId String?
  actor   User?   @relation("ConversationActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  action   ConversationActivityAction
  metadata Json?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([conversationId])
  @@index([actorId])
  @@index([action])
}

model Message {
  id String @id @default(cuid())

  // Tenant ownership
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Conversation relationship
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Message sender type
  sender MessageSender

  // Message content
  content String

  status            MessageStatus        @default(SENT)
  externalMessageId String?
  provider          ConversationChannel?
  metadata          Json?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attachments Attachment[]
  retryState  MessageRetryState?
  dlqItems    ChannelDeadLetterItem[]
  aiInteraction AIInteraction?

  @@index([companyId])
  @@index([conversationId])
  @@index([companyId, provider, externalMessageId])
  @@index([companyId, conversationId, createdAt, id])
}

model MessageRetryState {
  id String @id @default(cuid())

  messageId String @unique
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  provider ConversationChannel
  state    ChannelRetryState @default(PENDING)

  attemptCount Int @default(0)
  maxAttempts  Int @default(5)

  nextAttemptAt DateTime?
  lastAttemptAt DateTime?
  lastFailureAt DateTime?

  lastFailureCode   String?
  lastFailureReason String?
  lastHttpStatus    Int?

  lockedAt   DateTime?
  lockToken  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, provider, state, nextAttemptAt])
  @@index([state, nextAttemptAt])
}

model ChannelDeadLetterItem {
  id String @id @default(cuid())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  provider ConversationChannel
  reason   ChannelDlqReason
  state    ChannelDlqState @default(OPEN)

  sourceEventType String
  payload         Json

  messageId String?
  message   Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  externalMessageId String?
  providerAccountId String?

  failureCode   String?
  failureReason String
  failureMeta   Json?

  firstFailedAt DateTime @default(now())
  lastFailedAt  DateTime @default(now())

  retryCount    Int @default(0)
  nextRetryAt   DateTime?
  processedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provider, reason, state, nextRetryAt])
  @@index([companyId, state, nextRetryAt])
  @@index([externalMessageId])
}

model ReconciliationRun {
  id String @id @default(cuid())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  runType String
  status  ReconciliationRunStatus

  startedAt   DateTime @default(now())
  completedAt DateTime?

  scannedCount   Int @default(0)
  updatedCount   Int @default(0)
  createdDlqCount Int @default(0)

  errorMessage String?
  metadata     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([runType, status, startedAt])
  @@index([companyId, startedAt])
}

model WidgetInstallation {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  publicKey      String   @unique
  enabled        Boolean  @default(true)
  allowedDomains String[]

  // Phase 1: landing page customisation
  companyDisplayName String?
  welcomeTitle       String?
  welcomeSubtitle    String?
  chatGreeting       String?
  launcherLabel      String?
  footerNote         String?
  messageShortcuts   String[]

  // Phase 3: branding
  logoUrl      String?
  heroImageUrl String?
  brandColor   String?

  faqEntries        WidgetFaqEntry[]
  articleCategories WidgetArticleCategory[]
  articles          WidgetArticle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model WidgetFaqEntry {
  id String @id @default(cuid())

  widgetInstallationId String
  widgetInstallation   WidgetInstallation @relation(fields: [widgetInstallationId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  question  String
  answer    String
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([widgetInstallationId])
  @@index([companyId])
}

model WidgetArticleCategory {
  id                   String @id @default(cuid())
  companyId            String
  widgetInstallationId String
  name                 String
  slug                 String
  sortOrder            Int    @default(0)

  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  widgetInstallation WidgetInstallation @relation(fields: [widgetInstallationId], references: [id], onDelete: Cascade)
  articles           WidgetArticle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([widgetInstallationId, slug])
  @@index([companyId])
  @@index([widgetInstallationId])
  @@index([companyId, widgetInstallationId])
}

model WidgetArticle {
  id                   String              @id @default(cuid())
  companyId            String
  widgetInstallationId String
  title                String
  slug                 String
  summary              String
  content              String
  categoryId           String?
  status               WidgetArticleStatus @default(DRAFT)
  sortOrder            Int                 @default(0)
  publishedAt          DateTime?
  createdById          String?

  company            Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  widgetInstallation WidgetInstallation     @relation(fields: [widgetInstallationId], references: [id], onDelete: Cascade)
  category           WidgetArticleCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy          User?                  @relation("WidgetArticleCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([widgetInstallationId, slug])
  @@index([companyId])
  @@index([widgetInstallationId])
  @@index([companyId, widgetInstallationId])
  @@index([widgetInstallationId, status])
  @@index([categoryId])
  @@index([createdById])
}

model WhatsAppAccount {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  phoneNumberId      String
  displayPhoneNumber String?
  status             ProviderAccountStatus @default(ACTIVE)
  metadata           Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([phoneNumberId])
  @@index([companyId, status])
}

model EmailAccount {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  provider  EmailProvider      @default(RESEND)
  fromEmail String
  fromName  String?
  status    EmailAccountStatus @default(ACTIVE)
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, fromEmail])
  @@index([companyId, status])
}

model WebhookReplayLedger {
  id String @id @default(cuid())

  provider WebhookProvider
  eventType String
  identityKey String @unique

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  providerEventId       String?
  signatureFingerprint  String?
  payloadFingerprint    String
  firstSeenAt           DateTime @default(now())
  lastSeenAt            DateTime @default(now())
  firstRequestId        String?
  lastRequestId         String?
  seenCount             Int      @default(1)
  lastReason            String?
  metadata              Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provider, companyId, eventType])
  @@index([provider, providerEventId])
  @@index([companyId, updatedAt])
}

model Ticket {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  subject     String
  description String?

  status   TicketStatus   @default(OPEN)
  priority TicketPriority @default(MEDIUM)

  assigneeId String?
  assignee   User?   @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("TicketCreator", fields: [createdById], references: [id])

  firstResponseDueAt DateTime?
  resolutionDueAt    DateTime?
  firstRespondedAt   DateTime?
  resolvedAt         DateTime?
  slaStatus          SlaStatus @default(ON_TRACK)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes       TicketNote[]
  activities  TicketActivity[]
  tags        TicketTag[]
  attachments Attachment[]
  feedbackSurveys   FeedbackSurvey[]
  feedbackResponses FeedbackResponse[]

  @@index([companyId])
  @@index([conversationId])
  @@index([customerId])
  @@index([assigneeId])
  @@index([teamId])
  @@index([status])
  @@index([priority])
  @@index([companyId, slaStatus])
  @@index([companyId, updatedAt, id])
  @@index([companyId, status, updatedAt, id])
  @@index([companyId, assigneeId, updatedAt, id])
  @@index([companyId, teamId, updatedAt, id])
  @@index([companyId, priority, updatedAt, id])
  @@index([firstResponseDueAt])
  @@index([resolutionDueAt])
}

model SlaPolicy {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name                 String
  priority             TicketPriority
  firstResponseMinutes Int
  resolutionMinutes    Int
  enabled              Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId, priority, enabled])
}

model Attachment {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  uploadedById String?
  uploadedBy   User?   @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  messageId String?
  message   Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  ticketId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  fileName     String
  mimeType     String
  fileSize     Int
  storageKey   String                 @unique
  uploadedFrom AttachmentUploadedFrom

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([conversationId])
  @@index([messageId])
  @@index([ticketId])
  @@index([customerId])
}

model Team {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members         TeamMember[]
  tickets         Ticket[]
  conversations   Conversation[]
  assignmentRules AssignmentRule[]

  @@unique([companyId, name])
  @@index([companyId])
}

model TeamMember {
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([teamId, userId])
  @@index([companyId])
  @@index([userId])
}

model AssignmentRule {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name           String
  enabled        Boolean                     @default(true)
  targetType     AssignmentRuleTargetType
  conditionType  AssignmentRuleConditionType
  conditionValue String

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId, targetType, enabled, createdAt])
  @@index([companyId, teamId])
}

model TicketNote {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("TicketNoteAuthor", fields: [authorId], references: [id])

  content String

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([ticketId])
  @@index([authorId])
}

model TicketActivity {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  actorId String?
  actor   User?   @relation("TicketActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  action   TicketActivityAction
  metadata Json?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([ticketId])
  @@index([actorId])
  @@index([action])
}

model SavedReply {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  title   String
  content String

  createdById String
  createdBy   User   @relation("SavedReplyCreator", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([createdById])
  @@index([companyId, title])
}

model Tag {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name  String
  color String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers     CustomerTag[]
  conversations ConversationTag[]
  tickets       TicketTag[]

  @@unique([companyId, name])
  @@index([companyId])
}

model CustomerTag {
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([customerId, tagId])
  @@index([companyId])
  @@index([tagId])
}

model ConversationTag {
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([conversationId, tagId])
  @@index([companyId])
  @@index([tagId])
}

model TicketTag {
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([ticketId, tagId])
  @@index([companyId])
  @@index([tagId])
}

model AuditLog {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  actorId String?
  actor   User?   @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  action     String
  entityType String
  entityId   String
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([companyId, action])
  @@index([companyId, entityType])
  @@index([companyId, actorId])
  @@index([companyId, entityType, entityId])
}

model Notification {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type       NotificationType
  title      String
  message    String
  entityType String
  entityId   String
  metadata   Json?
  isRead     Boolean          @default(false)

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([companyId, userId, createdAt, id])
  @@index([companyId, userId, isRead, createdAt, id])
  @@index([companyId, userId, type, entityType, entityId])
}

model FeedbackTriggerConfig {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  source FeedbackTriggerSource
  mode   FeedbackTriggerMode   @default(CSAT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, source])
  @@index([companyId])
}

model FeedbackSurvey {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  ticketId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  channel ConversationChannel?

  assigneeId String?
  assignee   User? @relation("FeedbackSurveyAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  type          FeedbackSurveyType
  status        FeedbackSurveyStatus @default(PENDING)
  triggerSource FeedbackTriggerSource
  triggerEventKey String

  tokenHash String @unique
  expiresAt DateTime
  sentAt    DateTime?
  completedAt DateTime?

  response   FeedbackResponse?
  escalation FeedbackEscalation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, status, createdAt])
  @@index([companyId, type, status, createdAt])
  @@index([companyId, triggerSource, triggerEventKey])
  @@index([companyId, customerId])
  @@index([conversationId])
  @@index([ticketId])
  @@index([assigneeId])
}

model FeedbackResponse {
  id String @id @default(cuid())

  surveyId String @unique
  survey   FeedbackSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  ticketId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  channel ConversationChannel?

  assigneeId String?

  type      FeedbackSurveyType
  score     Int
  comment   String?
  sentiment FeedbackSentiment

  submittedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  escalation FeedbackEscalation?

  @@index([companyId])
  @@index([companyId, type, submittedAt])
  @@index([companyId, sentiment, submittedAt])
  @@index([companyId, channel, submittedAt])
  @@index([companyId, assigneeId, submittedAt])
  @@index([companyId, customerId])
  @@index([conversationId])
  @@index([ticketId])
}

model FeedbackEscalation {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  surveyId String @unique
  survey   FeedbackSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  responseId String @unique
  response   FeedbackResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  status FeedbackEscalationStatus @default(OPEN)
  reason String?

  assignedToId String?
  assignedTo   User? @relation("FeedbackEscalationAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, status, createdAt])
  @@index([companyId, assignedToId, status])
}

model AIInteraction {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  requestType AIInteractionRequestType
  inputContext Json

  generatedSuggestion String
  confidence Decimal @db.Decimal(5, 2)
  costMicroUSD Int?

  userAction AIInteractionUserAction?
  acceptedAt DateTime?
  editedContent String?

  sentAsMessageId String? @unique
  sentAsMessage Message? @relation(fields: [sentAsMessageId], references: [id], onDelete: SetNull)

  provider String
  modelId String?
  tokensUsed Int?
  responseTimeMs Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([conversationId])
  @@index([companyId, createdAt])
  @@index([companyId, userId, createdAt])
}
