generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  ADMIN
  TEAM_LEAD
  AGENT
  VIEWER
}

enum ConversationChannel {
  WEBSITE
  WHATSAPP
  INSTAGRAM
  EMAIL
}

enum MessageSender {
  CUSTOMER
  AGENT
  SYSTEM
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum TicketStatus {
  OPEN
  PENDING
  ESCALATED
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketActivityAction {
  TICKET_CREATED
  TICKET_CREATED_FROM_WIDGET
  TICKET_UPDATED
  STATUS_CHANGED
  PRIORITY_CHANGED
  ASSIGNED
  UNASSIGNED
  NOTE_ADDED
  MESSAGE_RECEIVED_ON_WIDGET
}

model Company {
  id        String    @id @default(cuid())
  name      String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users User[]
  customers Customer[]
  conversations Conversation[]
  messages Message[]
  widgetInstallations WidgetInstallation[]
  tickets Ticket[]
  ticketNotes TicketNote[]
  ticketActivities TicketActivity[]
  savedReplies SavedReply[]
  tags Tag[]
  customerTags CustomerTag[]
  conversationTags ConversationTag[]
  ticketTags TicketTag[]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String

  firstName     String
  lastName      String

  role UserRole @default(AGENT)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  assignedTickets Ticket[] @relation("TicketAssignee")
  createdTickets Ticket[] @relation("TicketCreator")
  ticketNotes TicketNote[] @relation("TicketNoteAuthor")
  ticketActivities TicketActivity[] @relation("TicketActivityActor")
  savedReplies SavedReply[] @relation("SavedReplyCreator")
}

model Customer {
  id String @id @default(cuid())

  // Tenant ownership
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Basic customer identity
  firstName String
  lastName  String?

  email String?
  phone String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Customer communication history
  conversations Conversation[]
  tickets Ticket[]
  tags CustomerTag[]
}

model Conversation {
  id String @id @default(cuid())

  // Tenant ownership
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Customer relationship
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  // Communication channel
  channel ConversationChannel

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages Message[]
  tickets Ticket[]
  tags ConversationTag[]

  @@index([companyId])
  @@index([customerId])
}

model Message {
  id String @id @default(cuid())

  // Tenant ownership
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Conversation relationship
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Message sender type
  sender MessageSender

  // Message content
  content String

  status MessageStatus @default(SENT)
  externalMessageId String?
  provider ConversationChannel?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([conversationId])
  @@index([companyId, provider, externalMessageId])
}

model WidgetInstallation {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  publicKey      String   @unique
  enabled        Boolean  @default(true)
  allowedDomains String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Ticket {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  subject     String
  description String?

  status   TicketStatus   @default(OPEN)
  priority TicketPriority @default(MEDIUM)

  assigneeId String?
  assignee   User? @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User @relation("TicketCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes TicketNote[]
  activities TicketActivity[]
  tags TicketTag[]

  @@index([companyId])
  @@index([conversationId])
  @@index([customerId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
}

model TicketNote {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorId String
  author   User @relation("TicketNoteAuthor", fields: [authorId], references: [id])

  content String

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([ticketId])
  @@index([authorId])
}

model TicketActivity {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  actorId String
  actor   User @relation("TicketActivityActor", fields: [actorId], references: [id])

  action TicketActivityAction
  metadata Json?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([ticketId])
  @@index([actorId])
  @@index([action])
}

model SavedReply {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  title   String
  content String

  createdById String
  createdBy   User @relation("SavedReplyCreator", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([createdById])
  @@index([companyId, title])
}

model Tag {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name  String
  color String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers CustomerTag[]
  conversations ConversationTag[]
  tickets TicketTag[]

  @@unique([companyId, name])
  @@index([companyId])
}

model CustomerTag {
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([customerId, tagId])
  @@index([companyId])
  @@index([tagId])
}

model ConversationTag {
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([conversationId, tagId])
  @@index([companyId])
  @@index([tagId])
}

model TicketTag {
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([ticketId, tagId])
  @@index([companyId])
  @@index([tagId])
}
