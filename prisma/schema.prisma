generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  ADMIN
  TEAM_LEAD
  AGENT
  VIEWER
}

enum ConversationChannel {
  WEBSITE
  WHATSAPP
  INSTAGRAM
  EMAIL
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  SNOOZED
}

enum ConversationActivityAction {
  STATUS_CHANGED
  TEAM_ASSIGNED
  TEAM_UNASSIGNED
  AUTO_TEAM_ASSIGNED
}

enum MessageSender {
  CUSTOMER
  AGENT
  SYSTEM
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum AttachmentUploadedFrom {
  AGENT
  CUSTOMER_WIDGET
}

enum TicketStatus {
  OPEN
  PENDING
  ESCALATED
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SlaStatus {
  ON_TRACK
  AT_RISK
  BREACHED
  PAUSED
}

enum TicketActivityAction {
  TICKET_CREATED
  TICKET_CREATED_FROM_WIDGET
  TICKET_UPDATED
  STATUS_CHANGED
  PRIORITY_CHANGED
  ASSIGNED
  UNASSIGNED
  NOTE_ADDED
  MESSAGE_RECEIVED_ON_WIDGET
  TEAM_ASSIGNED
  TEAM_UNASSIGNED
  AUTO_TEAM_ASSIGNED
  SLA_UPDATED
  SLA_BREACHED
}

enum AssignmentRuleTargetType {
  CONVERSATION
  TICKET
}

enum AssignmentRuleConditionType {
  CHANNEL
  PRIORITY
  TAG
}

enum EmailProvider {
  RESEND
}

enum EmailAccountStatus {
  ACTIVE
  DISABLED
}

model Company {
  id       String  @id @default(cuid())
  name     String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                  User[]
  customers              Customer[]
  conversations          Conversation[]
  messages               Message[]
  widgetInstallations    WidgetInstallation[]
  tickets                Ticket[]
  ticketNotes            TicketNote[]
  ticketActivities       TicketActivity[]
  conversationActivities ConversationActivity[]
  savedReplies           SavedReply[]
  tags                   Tag[]
  customerTags           CustomerTag[]
  conversationTags       ConversationTag[]
  ticketTags             TicketTag[]
  teams                  Team[]
  teamMembers            TeamMember[]
  attachments            Attachment[]
  auditLogs              AuditLog[]
  slaPolicies            SlaPolicy[]
  assignmentRules        AssignmentRule[]
  emailAccounts          EmailAccount[]
  authSessions           AuthSession[]
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String

  firstName String
  lastName  String

  role     UserRole @default(AGENT)
  isActive Boolean  @default(true)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedTickets        Ticket[]               @relation("TicketAssignee")
  createdTickets         Ticket[]               @relation("TicketCreator")
  ticketNotes            TicketNote[]           @relation("TicketNoteAuthor")
  ticketActivities       TicketActivity[]       @relation("TicketActivityActor")
  conversationActivities ConversationActivity[] @relation("ConversationActivityActor")
  savedReplies           SavedReply[]           @relation("SavedReplyCreator")
  teamMemberships        TeamMember[]
  attachments            Attachment[]           @relation("AttachmentUploader")
  auditLogs              AuditLog[]             @relation("AuditLogActor")
  authSessions           AuthSession[]
}

model AuthSession {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  tokenHash String @unique
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([companyId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Customer {
  id String @id @default(cuid())

  // Tenant ownership
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Basic customer identity
  firstName String
  lastName  String?

  email String?
  phone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Customer communication history
  conversations Conversation[]
  tickets       Ticket[]
  tags          CustomerTag[]
  attachments   Attachment[]
}

model Conversation {
  id String @id @default(cuid())

  // Tenant ownership
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Customer relationship
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  // Communication channel
  channel ConversationChannel
  status  ConversationStatus  @default(OPEN)
  subject String?

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages    Message[]
  tickets     Ticket[]
  tags        ConversationTag[]
  activities  ConversationActivity[]
  attachments Attachment[]

  @@index([companyId])
  @@index([customerId])
  @@index([status])
  @@index([teamId])
}

model ConversationActivity {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  actorId String?
  actor   User?  @relation("ConversationActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  action   ConversationActivityAction
  metadata Json?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([conversationId])
  @@index([actorId])
  @@index([action])
}

model Message {
  id String @id @default(cuid())

  // Tenant ownership
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Conversation relationship
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Message sender type
  sender MessageSender

  // Message content
  content String

  status            MessageStatus        @default(SENT)
  externalMessageId String?
  provider          ConversationChannel?
  metadata          Json?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attachments Attachment[]

  @@index([companyId])
  @@index([conversationId])
  @@index([companyId, provider, externalMessageId])
}

model WidgetInstallation {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  publicKey      String   @unique
  enabled        Boolean  @default(true)
  allowedDomains String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model EmailAccount {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  provider  EmailProvider      @default(RESEND)
  fromEmail String
  fromName  String?
  status    EmailAccountStatus @default(ACTIVE)
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, fromEmail])
  @@index([companyId, status])
}

model Ticket {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  subject     String
  description String?

  status   TicketStatus   @default(OPEN)
  priority TicketPriority @default(MEDIUM)

  assigneeId String?
  assignee   User?   @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("TicketCreator", fields: [createdById], references: [id])

  firstResponseDueAt DateTime?
  resolutionDueAt    DateTime?
  firstRespondedAt   DateTime?
  resolvedAt         DateTime?
  slaStatus          SlaStatus @default(ON_TRACK)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes       TicketNote[]
  activities  TicketActivity[]
  tags        TicketTag[]
  attachments Attachment[]

  @@index([companyId])
  @@index([conversationId])
  @@index([customerId])
  @@index([assigneeId])
  @@index([teamId])
  @@index([status])
  @@index([priority])
  @@index([companyId, slaStatus])
  @@index([firstResponseDueAt])
  @@index([resolutionDueAt])
}

model SlaPolicy {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name                 String
  priority             TicketPriority
  firstResponseMinutes Int
  resolutionMinutes    Int
  enabled              Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId, priority, enabled])
}

model Attachment {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  uploadedById String?
  uploadedBy   User?   @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  messageId String?
  message   Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  ticketId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  fileName     String
  mimeType     String
  fileSize     Int
  storageKey   String                 @unique
  uploadedFrom AttachmentUploadedFrom

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([conversationId])
  @@index([messageId])
  @@index([ticketId])
  @@index([customerId])
}

model Team {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       TeamMember[]
  tickets       Ticket[]
  conversations Conversation[]
  assignmentRules AssignmentRule[]

  @@unique([companyId, name])
  @@index([companyId])
}

model TeamMember {
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([teamId, userId])
  @@index([companyId])
  @@index([userId])
}

model AssignmentRule {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name          String
  enabled       Boolean                     @default(true)
  targetType    AssignmentRuleTargetType
  conditionType AssignmentRuleConditionType
  conditionValue String

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId, targetType, enabled, createdAt])
  @@index([companyId, teamId])
}

model TicketNote {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("TicketNoteAuthor", fields: [authorId], references: [id])

  content String

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([ticketId])
  @@index([authorId])
}

model TicketActivity {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  actorId String?
  actor   User?  @relation("TicketActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  action   TicketActivityAction
  metadata Json?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([ticketId])
  @@index([actorId])
  @@index([action])
}

model SavedReply {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  title   String
  content String

  createdById String
  createdBy   User   @relation("SavedReplyCreator", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([createdById])
  @@index([companyId, title])
}

model Tag {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name  String
  color String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers     CustomerTag[]
  conversations ConversationTag[]
  tickets       TicketTag[]

  @@unique([companyId, name])
  @@index([companyId])
}

model CustomerTag {
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([customerId, tagId])
  @@index([companyId])
  @@index([tagId])
}

model ConversationTag {
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([conversationId, tagId])
  @@index([companyId])
  @@index([tagId])
}

model TicketTag {
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([ticketId, tagId])
  @@index([companyId])
  @@index([tagId])
}

model AuditLog {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  actorId String?
  actor   User?   @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  action     String
  entityType String
  entityId   String
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([companyId, action])
  @@index([companyId, entityType])
  @@index([companyId, actorId])
  @@index([companyId, entityType, entityId])
}
