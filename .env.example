NODE_ENV=development
PORT=5001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/omnicore
JWT_SECRET=replace-with-at-least-32-characters-for-staging

APP_ORIGINS=http://localhost:3000
SOCKET_ORIGINS=http://localhost:3000
JSON_BODY_LIMIT=1mb
ATTACHMENT_STORAGE_DIR=storage/attachments
ATTACHMENT_MAX_FILE_SIZE_BYTES=10485760

# WhatsApp/Meta test credentials for staging only.
WHATSAPP_VERIFY_TOKEN=replace-with-meta-webhook-verify-token
WHATSAPP_APP_SECRET=replace-with-meta-app-secret
WHATSAPP_PHONE_NUMBER_ID=replace-with-test-phone-number-id
WHATSAPP_ACCESS_TOKEN=replace-with-test-access-token

# Development-only public ingestion fallback. Do not enable for staging.
DEVELOPMENT_INGESTION_COMPANY_ID=
ALLOW_UNSIGNED_WEBHOOKS_IN_DEVELOPMENT=false
