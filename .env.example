NODE_ENV=development
PORT=5001

# Local development database. DIRECT_URL may match DATABASE_URL locally.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/omnicore
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/omnicore

# Supabase + Render production/staging format:
# - Runtime DATABASE_URL must use the Supabase transaction pooler on port 6543.
# - pgbouncer=true enables Prisma's transaction-pooler compatibility.
# - Keep connection_limit small so each Render instance cannot exhaust the
#   Supabase pool. Increase only after measuring available pool capacity.
# DATABASE_URL=postgresql://postgres.dxxmzbzumqdbdmpjdluw:<password>@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
#
# - DIRECT_URL is used by Prisma migration/introspection commands through the
#   datasource directUrl setting. Use the Supabase direct or session connection
#   on port 5432 with a small connection limit. Do not use this URL at runtime.
# DIRECT_URL=postgresql://postgres.dxxmzbzumqdbdmpjdluw:<password>@aws-1-eu-central-1.pooler.supabase.com:5432/postgres?connection_limit=1&sslmode=require
#
# Render can run `npx prisma generate` and `npm run build` during build.
# Run `npx prisma migrate deploy` only as an intentional migration step; Prisma
# uses DIRECT_URL for that database connection. Never commit real credentials.

JWT_SECRET=replace-with-at-least-32-characters-for-staging

APP_ORIGINS=http://localhost:3000
SOCKET_ORIGINS=http://localhost:3000
JSON_BODY_LIMIT=1mb
ATTACHMENT_STORAGE_DIR=storage/attachments
ATTACHMENT_MAX_FILE_SIZE_BYTES=10485760

# WhatsApp/Meta test credentials for staging only.
WHATSAPP_VERIFY_TOKEN=replace-with-meta-webhook-verify-token
WHATSAPP_APP_SECRET=replace-with-meta-app-secret
WHATSAPP_PHONE_NUMBER_ID=replace-with-test-phone-number-id
WHATSAPP_ACCESS_TOKEN=replace-with-test-access-token

# Email provider credentials. Keep secrets in deployment environment only.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_WEBHOOK_SECRET=
#
# Local inbound email webhook test (development only; replace the address with
# an active Settings -> Channels email account):
# curl -X POST http://localhost:5001/api/v1/channels/email/webhook \
#   -H "Content-Type: application/json" \
#   -d '{"type":"omnicore.email.test","externalMessageId":"dev-email-001","fromEmail":"visitor@example.com","fromName":"Visitor Example","toEmail":"support@omnicore.test","subject":"Local email test","content":"Hello from a local email webhook test."}'

# Development-only public ingestion fallback. Do not enable for staging.
DEVELOPMENT_INGESTION_COMPANY_ID=
ALLOW_UNSIGNED_WEBHOOKS_IN_DEVELOPMENT=false
