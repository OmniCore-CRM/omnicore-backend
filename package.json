{
  "name": "omnichannel-crm-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "npm run start:staging",
    "start:staging": "tsx src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prisma:guard-shadow": "tsx scripts/ensure-prisma-shadow-safety.ts",
    "prisma:generate": "npm run prisma:guard-shadow && prisma generate",
    "prisma:migrate:status": "npm run prisma:guard-shadow && prisma migrate status",
    "prisma:seed": "npm run prisma:guard-shadow && prisma db seed",
    "seed:staging": "npm run prisma:guard-shadow && tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed-with-guard.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "prisma": "^6.19.3",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.2",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
